NODE_ENV=production
PORT=4173
APP_NAME=CareerForge AI
DATA_FILE=/app/data/store.json
DOMAIN=example.com

DEFAULT_PROVIDER=local-rules
AI_PROVIDER=deepseek
AI_API_BASE_URL=https://api.deepseek.com
AI_API_KEY=replace_with_your_deepseek_key
AI_MODEL_FAST=deepseek-v4-flash
AI_MODEL_REASONER=deepseek-v4-pro
AI_DEFAULT_MODEL=deepseek-v4-flash
AI_TIMEOUT_MS=180000
AI_TIMEOUT_REASONER_MS=240000

MAX_UPLOAD_MB=20
MAX_REQUEST_MB=35
